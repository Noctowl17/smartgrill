# Bluetooth MAC-adres van de ToGrill AT-02
TOGRILL_ADDRESS=C3:B3:63:51:60:7B

# Webserver instellingen
SMARTGRILL_HOST=0.0.0.0
SMARTGRILL_PORT=8000

# Aantal seconden wachten voordat opnieuw verbinding wordt gemaakt
RECONNECT_DELAY=10

# Na hoeveel seconden data als "stale" wordt beschouwd
STALE_AFTER=15
